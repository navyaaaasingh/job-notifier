{
  "name": "job-notifier",
  "version": "1.0.0",
  "description": "Fetches job listings from Adzuna, Reed and Jooble, matches them against saved user preferences, and sends email/SMS/push notifications when new matches appear.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check-now": "node -e \"require('./services/pipeline').runPipeline().then(()=>process.exit(0))\""
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lowdb": "^1.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "twilio": "^5.2.2",
    "uuid": "^9.0.1"
  }
}
